# ==========================================
# NovelCraft OS 专属防御清单
# ==========================================

# 1. 核心机密 (绝对不能上传 API Keys！)
.env
.env.*
!.env.example

# 2. 虚拟环境 (极度臃肿，不需要上传)
venv/
.venv/
env/
**/venv/
model_manager.json

# 3. 记忆库与本地数据 (防覆盖与隐私泄露)
*.db
*.sqlite3
*.sqlite
data/ 
temp_generations/

# 4. Python 编译缓存 (垃圾文件)
__pycache__/
*.py[cod]
*$py.class
*.so
.pytest_cache/

# 5. IDE 与操作系统生成文件 (保持云端整洁)
.vscode/
.idea/
.DS_Store
Thumbs.db


# 6. 测试用例生成 (防污染)
test_*
